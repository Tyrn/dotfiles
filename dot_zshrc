source ~/.antidote/antidote.zsh
antidote load

# The community vi-mode plugins turned out to be invasive and/or
# short on this or that. Some lines below are a native substitute.
bindkey -v
# Restore Ctrl+N and Ctrl+P for history navigation in insert mode
bindkey -M viins '^N' down-line-or-history
bindkey -M viins '^P' up-line-or-history

# shellcheck disable=SC2034
# Set up vi mode indicator (separate from Oh My Posh).
# NB This will overwrite the right prompt of the theme, if any.
function vi-mode-rshow() {
  if [[ $KEYMAP == vicmd ]]; then
    echo -ne '\e[2 q'
    RPS1="%F{gold}❮N❯%f"
  else
    echo -ne '\e[6 q'
    RPS1="%F{green}❮I❯%f"
  fi
  zle reset-prompt
}

# Register the vi mode indicator as the special widgets
zle -N zle-line-init vi-mode-rshow
zle -N zle-keymap-select vi-mode-rshow

# Yank to system clipboard from vi-mode
function vi-yank-system-clipboard {
  zle vi-yank
  if [[ -n $CUTBUFFER ]]; then
    # Prefer wl-copy (Wayland), then xclip (X11), then pbcopy (macOS)
    if command -v wl-copy &>/dev/null; then
      echo -n "$CUTBUFFER" | wl-copy
    elif command -v xclip &>/dev/null; then
      echo -n "$CUTBUFFER" | xclip -selection clipboard
    elif command -v pbcopy &>/dev/null; then
      echo -n "$CUTBUFFER" | pbcopy
    else
      echo "zsh vi-mode: No clipboard tool found (wl-copy, xclip, or pbcopy)"
    fi
  fi
}
zle -N vi-yank-system-clipboard
bindkey -M vicmd 'y' vi-yank-system-clipboard

eval "$(oh-my-posh init zsh --config ~/.config/oh-my-posh/custom_lean.omp.json)"

# Enable smart cd.
eval "$(zoxide init zsh)"
alias cd=z
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# A very special case of IBus (scripted switch).
if [[ "$XDG_CURRENT_DESKTOP" == "GNOME" ]]; then
  source ~/.gnome-kbd-lib.sh
fi

source ~/.assorted-helpers.sh

eval "$(zsh-patina activate)"
eval "$(mise activate zsh)"

